{
  "compilerOptions": {
    // ── Language / target ─────────────────────────────────────────────────
    "target": "esnext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": false,
    "experimentalDecorators": true,

    // ── Module output ─────────────────────────────────────────────────────
    // ESM emit so the package can be consumed by Vite / Rollup / webpack
    // worker bundlers without needing a separate Vite/Rollup pass to produce
    // an ESM wrapper. `bundler` resolution lets the source keep extension-less
    // imports (`./Log` instead of `./Log.js`) while still emitting valid ESM.
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],

    // ── Emit ──────────────────────────────────────────────────────────────
    "declaration": true,
    "outDir": "dist",

    // ── Interop ───────────────────────────────────────────────────────────
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    // ── Type-checking ─────────────────────────────────────────────────────
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,

    // ── Lit (custom-element / decorator) options ──────────────────────────
    "moduleDetection": "force",
    "noUncheckedSideEffectImports": true
  },
  "exclude": ["dist", "node_modules", "tests"],
  "include": ["src"]
}
